<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta http-equiv="refresh" content="2">
    <style>
        #tabla {
            border-collapse: collapse;
            margin-top: 20px;
        }
        /* Estilos visuales cambiados: bordes definidos y fondo oscuro personalizado */
        td {
            width: 80px;
            height: 80px;
            border: 2px solid #444;
            text-align: center;
            font-family: sans-serif;
            font-weight: bold;
            background-color: #2a2a2a; /* Fondo gris oscuro base */
            color: #888;
            transition: background-color 0.3s;
        }
        
        /* Paleta de colores personalizados para cada cuadrante */
        .color-rojo { background-color: #e74c3c !important; color: white !important; }
        .color-azul { background-color: #3498db !important; color: white !important; }
        .color-amarillo { background-color: #f1c40f !important; color: black !important; }
        .color-verde { background-color: #2ecc71 !important; color: white !important; }
    </style>
</head>

<body style="background-color: #121212; color: white; font-family: sans-serif; padding: 20px;">

    <!-- Barra de Navegación Estática (Sin JavaScript) -->
    <div id="menu-navegacion" style="background-color: #222; padding: 15px; text-align: center; margin-bottom: 25px; border-bottom: 3px solid #00ff00;">
        <a href="/" style="color: #00ff00; margin: 0 15px; text-decoration: none; font-weight: bold;">[ Matriz Principal ]</a>
        <a href="/info" style="color: #ffffff; margin: 0 15px; text-decoration: none; font-weight: bold;">[ Vista Alternativa (jfpc) ]</a>
        <a href="/mensaje" style="color: #ffffff; margin: 0 15px; text-decoration: none; font-weight: bold;">[ Mensajes del Sistema ]</a>
    </div>

   <h1>Posición XY (Matriz 4x4)</h1>

    <p>X = {{ ejeX }}</p>
    <p>Y = {{ ejeY }}</p>

    <!-- Estructura de la Matriz Superior 4x4 con Representación Creativa X-Y -->
    <table id="tabla">
        <!-- Fila 1 (Extremos Superiores) -->
        <tr>
            <td id="m1" class="{% if ejeX < -5 and ejeY > 5 %}color-rojo{% endif %}">M1</td>
            <td id="m2" class="{% if ejeX >= -5 and ejeX < 0 and ejeY > 5 %}color-rojo{% endif %}">M2</td>
            <td id="m3" class="{% if ejeX >= 0 and ejeX <= 5 and ejeY > 5 %}color-azul{% endif %}">M3</td>
            <td id="m4" class="{% if ejeX > 5 and ejeY > 5 %}color-azul{% endif %}">M4</td>
        </tr>
        <!-- Fila 2 (Centro Superior) -->
        <tr>
            <td id="m5" class="{% if ejeX < -5 and ejeY >= 0 and ejeY <= 5 %}color-rojo{% endif %}">M5</td>
            <td id="m6" class="{% if ejeX >= -5 and ejeX < 0 and ejeY >= 0 and ejeY <= 5 %}color-rojo{% endif %}">M6</td>
            <td id="m7" class="{% if ejeX >= 0 and ejeX <= 5 and ejeY >= 0 and ejeY <= 5 %}color-azul{% endif %}">M7</td>
            <td id="m8" class="{% if ejeX > 5 and ejeY >= 0 and ejeY <= 5 %}color-azul{% endif %}">M8</td>
        </tr>
        <!-- Fila 3 (Centro Inferior) -->
        <tr>
            <td id="m9" class="{% if ejeX < -5 and ejeY >= -5 and ejeY < 0 %}color-amarillo{% endif %}">M9</td>
            <td id="m10" class="{% if ejeX >= -5 and ejeX < 0 and ejeY >= -5 and ejeY < 0 %}color-amarillo{% endif %}">M10</td>
            <td id="m11" class="{% if ejeX >= 0 and ejeX <= 5 and ejeY >= -5 and ejeY < 0 %}color-verde{% endif %}">M11</td>
            <td id="m12" class="{% if ejeX > 5 and ejeY >= -5 and ejeY < 0 %}color-verde{% endif %}">M12</td>
        </tr>
        <!-- Fila 4 (Extremos Inferiores) -->
        <tr>
            <td id="m13" class="{% if ejeX < -5 and ejeY < -5 %}color-amarillo{% endif %}">M13</td>
            <td id="m14" class="{% if ejeX >= -5 and ejeX < 0 and ejeY < -5 %}color-amarillo{% endif %}">M14</td>
            <td id="m15" class="{% if ejeX >= 0 and ejeX <= 5 and ejeY < -5 %}color-verde{% endif %}">M15</td>
            <td id="m16" class="{% if ejeX > 5 and ejeY < -5 %}color-verde{% endif %}">M16</td>
        </tr>
    </table>

</body>
</html>
